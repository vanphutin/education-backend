# ------------------------------------------------------------------------------
# Movie Ticket Booking API - Environment Configuration Template
# Sao chép file này thành '.env' và cấu hình các giá trị thực tế
# ------------------------------------------------------------------------------

# 1. Cấu hình Server chính (App Configuration)
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1

# 2. Cấu hình Cơ sở dữ liệu (PostgreSQL Database Configuration)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=movie_booking_db
DB_SSL=false
DB_SYNCHRONIZE=false

# 3. Cấu hình Redis & BullMQ (Queue Configuration)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 4. Cấu hình bảo mật Auth (JWT Tokens)
JWT_SECRET=super_secret_access_token_key_change_me_in_production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=super_secret_refresh_token_key_change_me_in_production
JWT_REFRESH_EXPIRATION=7d

# 5. Tích hợp cổng thanh toán payOS (payOS Payment Integration)
# Lấy thông tin từ trang quản trị payOS của bạn
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# 6. Tích hợp Trí tuệ nhân tạo AI (AI & Embeddings Integration)
# Tùy chọn: mock | openai
AI_PROVIDER=mock
EMBEDDING_PROVIDER=mock

# Key API nếu cấu hình real provider (ví dụ OpenAI)
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
